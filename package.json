{
    "name": "gemma-4-extension",
    "displayName": "Gemma 4 Local AI",
    "description": "Local Gemma 4 AI Bridge for Antigravity",
    "version": "1.0.0",
    "publisher": "Kodari",
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onView:gemma-chat-view",
        "onCommand:gemma.open"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "gemma.open",
                "title": "Gemma 4: Open",
                "icon": "media/icon.svg"
            }
        ],
        "menus": {
            "editor/title": [
                {
                    "command": "gemma.open",
                    "group": "navigation",
                    "when": "true"
                }
            ]
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "gemma-explorer",
                    "title": "Gemma 4",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "gemma-explorer": [
                {
                    "type": "webview",
                    "id": "gemma-chat-view",
                    "name": "Gemma 4 Chat"
                }
            ]
        }
    }
}
